DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
DISCORD_OWNER_ID=

OSU_CLIENT_ID=
OSU_CLIENT_SECRET=

# Must match the redirect URL in your osu! OAuth application settings.
# Defaults to {BASE_URL}/auth/osu/callback if unset.
# OSU_REDIRECT_URI=https://your-service.onrender.com/auth/osu/callback

BASE_URL=http://localhost:8000

# Comma-separated origins for a separate frontend (e.g. https://app.example.com,http://localhost:5173)
# CORS_ORIGINS=
WEBHOOK_SECRET=change-me
DATABASE_PATH=./data/bot_data.db
ROLE_MAPPING_PATH=./config/role_mapping.json
VERIFICATION_MODE=rank_digit_count
DIGIT_MODULUS=10
VERIFICATION_TOKEN_TTL_SECONDS=900
LINK_CODE_TTL_SECONDS=900
RATE_LIMIT_PER_MINUTE=15
OSU_CACHE_TTL_SECONDS=30
